---
import RibbonMotif from './RibbonMotif.astro';
import { services } from '../data/services';

const currentPath = Astro.url.pathname;

function active(href: string): boolean {
	if (href === '/') return currentPath === '/';
	return currentPath.startsWith(href);
}

const mediaLinks = [
	{ href: '/gallery', label: 'Gallery' },
	{ href: '/blog', label: 'Blog' },
];
---

<header id="site-header" class="sticky top-0 z-50 border-b border-card-border bg-white/90 backdrop-blur transition-shadow duration-300">
	<RibbonMotif class="pointer-events-none absolute right-4 top-1/2 hidden h-12 w-12 -translate-y-1/2 opacity-10 md:right-12 md:block md:h-14 md:w-14" />

	<nav class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-3 md:px-10">
		<!-- Logo -->
		<a href="/" class="flex items-center gap-3">
			<img src="/logo.jpg" alt="Technosworld" width="64" height="64" class="h-16 w-16 rounded-md" />
			<span class="leading-tight">
				<span class="block text-lg font-bold text-navy">TECHNOSWORLD</span>
				<span class="block text-[10px] font-medium uppercase tracking-[0.25em] text-muted">Automate. Build. Grow</span>
			</span>
		</a>

		<!-- Desktop nav -->
		<div class="hidden items-center gap-7 md:flex">

			<!-- Home -->
			<a
				href="/"
				class={`group relative py-2 text-sm font-medium transition-colors hover:text-navy-bright ${active('/') ? 'text-navy-bright' : 'text-charcoal'}`}
			>
				Home
				<span class={`absolute -bottom-0.5 left-0 h-0.5 w-full origin-left bg-navy-bright transition-transform duration-300 group-hover:scale-x-100 ${active('/') ? 'scale-x-100' : 'scale-x-0'}`}></span>
			</a>

			<!-- About -->
			<a
				href="/about"
				class={`group relative py-2 text-sm font-medium transition-colors hover:text-navy-bright ${active('/about') ? 'text-navy-bright' : 'text-charcoal'}`}
			>
				About
				<span class={`absolute -bottom-0.5 left-0 h-0.5 w-full origin-left bg-navy-bright transition-transform duration-300 group-hover:scale-x-100 ${active('/about') ? 'scale-x-100' : 'scale-x-0'}`}></span>
			</a>

			<!-- Services — hover dropdown -->
			<div class="group relative">
				<a
					href="/#services"
					class={`flex items-center gap-1 py-2 text-sm font-medium transition-colors hover:text-navy-bright relative ${active('/services') ? 'text-navy-bright' : 'text-charcoal'}`}
				>
					Services
					<svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
					<span class={`absolute -bottom-0.5 left-0 h-0.5 w-full origin-left bg-navy-bright transition-transform duration-300 group-hover:scale-x-100 ${active('/services') ? 'scale-x-100' : 'scale-x-0'}`}></span>
				</a>
				<!-- Dropdown panel — shown on group hover via CSS -->
				<div class="invisible absolute left-0 top-full z-50 w-64 pt-2 opacity-0 transition-opacity duration-150 group-hover:visible group-hover:opacity-100">
					<div class="rounded-xl border border-card-border bg-white p-2 shadow-xl">
						<p class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-muted">Our services</p>
						{services.map((s) => (
							<a
								href={`/services/${s.slug}`}
								class={`block rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-surface hover:text-navy ${currentPath === `/services/${s.slug}` ? 'font-semibold text-navy' : 'text-charcoal'}`}
							>
								{s.title}
							</a>
						))}
					</div>
				</div>
			</div>

			<!-- Media — hover dropdown -->
			<div class="group relative">
				<a
					href="/gallery"
					class={`flex items-center gap-1 py-2 text-sm font-medium transition-colors hover:text-navy-bright relative ${active('/gallery') || active('/blog') ? 'text-navy-bright' : 'text-charcoal'}`}
				>
					Media
					<svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
					<span class={`absolute -bottom-0.5 left-0 h-0.5 w-full origin-left bg-navy-bright transition-transform duration-300 group-hover:scale-x-100 ${active('/portfolio') || active('/insights') ? 'scale-x-100' : 'scale-x-0'}`}></span>
				</a>
				<!-- Dropdown panel -->
				<div class="invisible absolute left-0 top-full z-50 w-48 pt-2 opacity-0 transition-opacity duration-150 group-hover:visible group-hover:opacity-100">
					<div class="rounded-xl border border-card-border bg-white p-2 shadow-xl">
						{mediaLinks.map((link) => (
							<a
								href={link.href}
								class={`block rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-surface hover:text-navy ${currentPath === link.href ? 'font-semibold text-navy' : 'text-charcoal'}`}
							>
								{link.label}
							</a>
						))}
					</div>
				</div>
			</div>

			<!-- Contact -->
			<a
				href="/contact"
				class={`group relative py-2 text-sm font-medium transition-colors hover:text-navy-bright ${active('/contact') ? 'text-navy-bright' : 'text-charcoal'}`}
			>
				Contact
				<span class={`absolute -bottom-0.5 left-0 h-0.5 w-full origin-left bg-navy-bright transition-transform duration-300 group-hover:scale-x-100 ${active('/contact') ? 'scale-x-100' : 'scale-x-0'}`}></span>
			</a>
		</div>

		<a href="/contact" class="btn-primary hidden md:inline-flex">Start a project</a>

		<button
			id="nav-toggle"
			aria-label="Toggle navigation menu"
			aria-expanded="false"
			class="flex h-10 w-10 items-center justify-center rounded-[7px] border border-card-border md:hidden"
		>
			<svg id="nav-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="nav-icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</nav>

	<!-- Mobile menu -->
	<div id="nav-mobile" class="hidden border-t border-card-border bg-white px-6 py-4 md:hidden">
		<div class="flex flex-col gap-1">
			<a href="/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-charcoal hover:bg-surface hover:text-navy-bright">Home</a>
			<a href="/about" class="rounded-lg px-3 py-2.5 text-sm font-medium text-charcoal hover:bg-surface hover:text-navy-bright">About</a>

			<!-- Mobile Services accordion -->
			<div>
				<button id="mob-services-btn" aria-expanded="false" class="flex w-full items-center justify-between rounded-lg px-3 py-2.5 text-sm font-medium text-charcoal hover:bg-surface hover:text-navy-bright">
					Services
					<svg id="mob-services-chev" class="h-3.5 w-3.5 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</button>
				<div id="mob-services-sub" class="hidden pl-3 pt-1">
					{services.map((s) => (
						<a href={`/services/${s.slug}`} class="block rounded-lg px-3 py-2 text-sm text-charcoal hover:text-navy">{s.title}</a>
					))}
				</div>
			</div>

			<!-- Mobile Media accordion -->
			<div>
				<button id="mob-media-btn" aria-expanded="false" class="flex w-full items-center justify-between rounded-lg px-3 py-2.5 text-sm font-medium text-charcoal hover:bg-surface hover:text-navy-bright">
					Media
					<svg id="mob-media-chev" class="h-3.5 w-3.5 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</button>
				<div id="mob-media-sub" class="hidden pl-3 pt-1">
					{mediaLinks.map((link) => (
						<a href={link.href} class="block rounded-lg px-3 py-2 text-sm text-charcoal hover:text-navy">{link.label}</a>
					))}
				</div>
			</div>

			<a href="/contact" class="rounded-lg px-3 py-2.5 text-sm font-medium text-charcoal hover:bg-surface hover:text-navy-bright">Contact</a>

			<div class="pt-2">
				<a href="/contact" class="btn-primary justify-center">Start a project</a>
			</div>
		</div>
	</div>
</header>

<script>
	// Mobile hamburger
	const toggle = document.getElementById('nav-toggle');
	const mobile = document.getElementById('nav-mobile');
	const iconOpen = document.getElementById('nav-icon-open');
	const iconClose = document.getElementById('nav-icon-close');

	toggle?.addEventListener('click', () => {
		const isOpen = mobile?.classList.toggle('hidden') === false;
		toggle.setAttribute('aria-expanded', String(isOpen));
		iconOpen?.classList.toggle('hidden', isOpen);
		iconClose?.classList.toggle('hidden', !isOpen);
	});

	mobile?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			mobile.classList.add('hidden');
			iconOpen?.classList.remove('hidden');
			iconClose?.classList.add('hidden');
			toggle?.setAttribute('aria-expanded', 'false');
		});
	});

	// Mobile Services accordion
	const mobServicesBtn = document.getElementById('mob-services-btn');
	const mobServicesSub = document.getElementById('mob-services-sub');
	const mobServicesChev = document.getElementById('mob-services-chev');
	mobServicesBtn?.addEventListener('click', () => {
		const open = mobServicesSub?.classList.toggle('hidden') === false;
		mobServicesBtn.setAttribute('aria-expanded', String(open));
		mobServicesChev?.classList.toggle('rotate-180', open);
	});

	// Mobile Media accordion
	const mobMediaBtn = document.getElementById('mob-media-btn');
	const mobMediaSub = document.getElementById('mob-media-sub');
	const mobMediaChev = document.getElementById('mob-media-chev');
	mobMediaBtn?.addEventListener('click', () => {
		const open = mobMediaSub?.classList.toggle('hidden') === false;
		mobMediaBtn.setAttribute('aria-expanded', String(open));
		mobMediaChev?.classList.toggle('rotate-180', open);
	});

	// Header scroll shadow
	const header = document.getElementById('site-header');
	const onScroll = () => {
		header?.classList.toggle('shadow-md', window.scrollY > 10);
		header?.classList.toggle('bg-white/95', window.scrollY > 10);
		header?.classList.toggle('bg-white/90', window.scrollY <= 10);
	};
	onScroll();
	window.addEventListener('scroll', onScroll, { passive: true });
</script>
