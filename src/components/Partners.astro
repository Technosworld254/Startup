---
const sectors = [
	'Restaurants & cafes',
	'SACCOs',
	'Hospitals & clinics',
	'Clubs & social venues',
	'Hotels & hospitality',
	'Retail & SMEs',
];
---

<section class="border-y border-card-border bg-white py-12">
	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<p class="eyebrow mb-8 text-center">Built for businesses like</p>
	</div>

	<div class="pause-on-hover overflow-hidden">
		<div class="animate-marquee flex w-max items-center gap-16">
			{[...sectors, ...sectors].map((sector) => (
				<span class="whitespace-nowrap text-xl font-bold text-muted">{sector}</span>
			))}
		</div>
	</div>
</section>
