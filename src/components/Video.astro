---
import RibbonMotif from './RibbonMotif.astro';
---

<section class="bg-white">
	<div class="mx-auto max-w-5xl px-6 py-20 md:px-10 md:py-28">
		<div class="reveal mx-auto max-w-3xl text-center">
			<p class="eyebrow mb-4">See us in action</p>
			<h2 class="text-3xl font-bold text-navy md:text-4xl">A closer look at how we work</h2>
			<p class="mt-6 text-lg text-charcoal">
				A short introduction to Technosworld — who we are, how we work with clients,
				and what it's like to build with us.
			</p>
		</div>

		<div class="reveal relative mt-12 aspect-video overflow-hidden rounded-xl bg-navy">
			<RibbonMotif class="absolute inset-0 m-auto h-40 w-40 opacity-20 md:h-56 md:w-56" />
			<div class="absolute inset-0 bg-navy/65"></div>
			<button
				aria-label="Play video"
				class="absolute inset-0 flex items-center justify-center"
			>
				<span class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-white/80 bg-white/10 transition-transform duration-150 hover:scale-105 md:h-20 md:w-20">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white md:h-8 md:w-8" viewBox="0 0 24 24" fill="currentColor">
						<path d="M8 5v14l11-7z" />
					</svg>
				</span>
			</button>
			<p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm font-medium text-white/80">
				Video coming soon
			</p>
		</div>
	</div>
</section>
