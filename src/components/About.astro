---
const stats = [
	{
		value: 'Kutus',
		label: 'Headquartered in Kirinyaga County, Kenya',
		icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M12 21c4.5-4.5 7.5-8.029 7.5-11.25a7.5 7.5 0 10-15 0c0 3.221 3 6.75 7.5 11.25z',
	},
	{
		value: '4+',
		label: 'Priority sectors — restaurants, SACCOs, hospitals, clubs',
		icon: 'M4 4h7v7H4V4zM13 4h7v7h-7V4zM4 13h7v7H4v-7zM13 13h7v7h-7v-7z',
	},
	{
		value: '2',
		label: 'Founders, both software engineers',
		icon: 'M15 6.75a3 3 0 11-6 0 3 3 0 016 0zM18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198a11.944 11.944 0 01-12 0M18 18.72a3 3 0 00-4.682-2.72M6 18.72a3 3 0 014.682-2.72',
	},
	{
		value: 'EA',
		label: 'Built for Kenya, growing across East Africa',
		icon: 'M12 21a9 9 0 100-18 9 9 0 000 18zM3.6 9h16.8M3.6 15h16.8M12 3a13.5 13.5 0 010 18M12 3a13.5 13.5 0 000 18',
	},
];

const story = [
	{
		tag: 'The Epidemic',
		title: 'The Unfinished Web Epidemic',
		description:
			'Technosworld started in Kutus, Kirinyaga, with a simple observation: most small businesses across the region either had no website at all, or had paid for one that nobody maintained after launch.',
	},
	{
		tag: 'The Catalyst',
		title: 'Ghosted: When Developers Disappear',
		description:
			'A local restaurant owner told us their site had been offline for months — the developer who built it had moved on and stopped replying. That conversation became the reason Technosworld exists.',
	},
	{
		tag: 'Our Promise',
		title: 'Engineers Who Actually Stick Around',
		description:
			'We\'re two developers with backgrounds in computer science and IT, and we built Technosworld to do what most agencies don\'t — show up, build something real, and stick around.',
	},
];

const roadmap = [
	{
		tag: 'Today',
		title: 'Digital Dominance: TechnosWeb & Reach',
		description:
			'Websites and digital tools for restaurants, hotels and SMEs across Kirinyaga and East Africa.',
	},
	{
		tag: 'Building toward',
		title: 'The Future: AI & Core Systems',
		description:
			'Custom software and AI tools for the businesses we serve today — built for what they\'ll need tomorrow.',
	},
];
---

<section id="about" class="bg-white">
	<div class="mx-auto max-w-7xl px-6 py-20 md:px-10 md:py-28">
		<div class="reveal mx-auto max-w-3xl text-center">
			<p class="eyebrow mb-4">Who we are</p>
			<h2 class="text-3xl font-bold text-navy md:text-4xl">
				Two developers, one simple problem, and a company built to stick around.
			</h2>
		</div>

		<div class="reveal mt-16 grid grid-cols-1 gap-6 md:grid-cols-3">
			{story.map((item) => (
				<div class="card group cursor-pointer transition-all duration-500 hover:shadow-xl hover:-translate-y-2 focus:scale-105 focus:shadow-2xl focus:z-10 bg-white outline-none" tabindex="0">
					<p class="eyebrow mb-3 transition-colors duration-300 group-hover:text-navy-bright">{item.tag}</p>
					<h3 class="text-lg font-bold text-navy">{item.title}</h3>
					<p class="mt-3 text-charcoal">{item.description}</p>
				</div>
			))}
		</div>

		<div class="reveal mt-6 grid grid-cols-1 gap-6 md:grid-cols-2">
			{roadmap.map((step) => (
				<div class="card group cursor-pointer transition-all duration-500 hover:shadow-xl hover:-translate-y-2 focus:scale-105 focus:shadow-2xl focus:z-10 bg-white outline-none" tabindex="0">
					<p class="eyebrow mb-3 transition-colors duration-300 group-hover:text-navy-bright">{step.tag}</p>
					<h3 class="text-lg font-bold text-navy">{step.title}</h3>
					<p class="mt-3 text-charcoal">{step.description}</p>
				</div>
			))}
		</div>

		<p class="reveal mt-12 text-center text-2xl font-bold text-navy md:text-3xl">
			Technosworld is being built for the long term — from Kutus, for Africa.
		</p>

		<div class="reveal mt-6 text-center">
			<a
				href="/about"
				class="inline-flex items-center gap-1.5 rounded-full border border-navy px-5 py-2 text-sm font-bold text-navy transition-all duration-200 hover:bg-navy hover:text-white"
			>
				Read the full story
				<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
				</svg>
			</a>
		</div>

		<div class="reveal mt-16 grid grid-cols-1 gap-10 border-t border-card-border pt-16 md:grid-cols-2 md:items-center md:gap-16">
			<div class="relative overflow-hidden rounded-2xl">
				<img
					src="/images/about/team-at-work.jpg"
					alt="A Technosworld developer working across multiple screens"
					class="h-full w-full object-cover"
				/>
				<div class="absolute inset-0 bg-navy/65 mix-blend-multiply"></div>
			</div>

			<div class="grid grid-cols-2 gap-6">
				{stats.map((stat) => (
					<div class="card">
						<div class="flex h-10 w-10 items-center justify-center rounded-full bg-surface text-navy-bright">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
								<path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
							</svg>
						</div>
						<div class="mt-4 text-3xl font-bold text-navy md:text-4xl">{stat.value}</div>
						<div class="mt-2 text-sm text-muted">{stat.label}</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
