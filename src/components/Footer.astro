---
import RibbonMotif from './RibbonMotif.astro';

const year = new Date().getFullYear();

const columns = [
	{
		title: 'Services',
		links: [
			{ label: 'Websites & online presence', href: '#services' },
			{ label: 'Business & management software', href: '#services' },
			{ label: 'AI tools', href: '#services' },
			{ label: 'Digital infrastructure', href: '#services' },
		],
	},
	{
		title: 'Sectors',
		links: [
			{ label: 'Restaurants & cafes', href: '#services' },
			{ label: 'SACCOs', href: '#services' },
			{ label: 'Hospitals & clinics', href: '#services' },
			{ label: 'Clubs & social venues', href: '#services' },
		],
	},
	{
		title: 'Company',
		links: [
			{ label: 'Services', href: '#services' },
			{ label: 'About', href: '#about' },
			{ label: 'Where we work', href: '#presence' },
			{ label: 'Testimonials', href: '#testimonials' },
		],
	},
];
---

<footer class="relative overflow-hidden bg-footer-navy text-silver">
	<RibbonMotif class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 opacity-[0.06] md:h-80 md:w-80" />

	<div class="relative mx-auto max-w-7xl px-6 py-16 md:px-10">
		<div class="grid grid-cols-1 gap-12 md:grid-cols-5">
			<div class="md:col-span-2">
				<a href="#top" class="flex items-center gap-3">
					<img src="/logo.jpg" alt="Technosworld" width="40" height="40" class="h-10 w-10 rounded-md" />
					<span class="leading-tight">
						<span class="block text-lg font-bold text-white">TECHNOSWORLD</span>
						<span class="block text-[10px] font-medium uppercase tracking-[0.25em] text-silver">Automate. Build. Grow</span>
					</span>
				</a>
				<p class="mt-6 max-w-sm text-sm text-silver/80">
					Websites, software, AI tools and digital infrastructure for businesses across
					Kirinyaga County, Kenya — and, over time, East Africa.
				</p>

				<div class="mt-6 space-y-3">
					<a href="https://maps.google.com/?q=Kutus,+Kirinyaga+County,+Kenya" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-silver/80 transition-colors hover:text-white">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 21c4.5-4.5 7.5-8.029 7.5-11.25a7.5 7.5 0 10-15 0c0 3.221 3 6.75 7.5 11.25z" />
						</svg>
						Kutus, Kirinyaga County, Kenya
					</a>
					<a href="mailto:hello@technosworld.com" class="flex items-center gap-3 text-sm text-silver/80 transition-colors hover:text-white">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
						</svg>
						hello@technosworld.com
					</a>
				</div>
			</div>

			{columns.map((column) => (
				<div>
					<h3 class="text-sm font-bold uppercase tracking-[0.2em] text-white">{column.title}</h3>
					<ul class="mt-4 space-y-3">
						{column.links.map((link) => (
							<li class="text-sm text-silver/80">
								<a href={link.href} class="transition-colors hover:text-white">{link.label}</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-sm text-silver/70 md:flex-row">
			<p>&copy; {year} Technosworld. All rights reserved.</p>
			<p>Built in Kutus, Kirinyaga County, Kenya.</p>
			<a href="#top" class="flex items-center gap-2 transition-colors hover:text-white">
				Back to top
				<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
				</svg>
			</a>
		</div>
	</div>
</footer>
