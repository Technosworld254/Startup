---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Contact Technosworld — Get in touch"
	description="Talk to the Technosworld team. Based in Kutus, Kirinyaga County. We reply within 24 hours."
>
	<!-- Breadcrumb -->
	<div class="border-b border-card-border bg-surface">
		<div class="mx-auto flex max-w-7xl items-center gap-2 px-6 py-3 text-sm md:px-10">
			<a href="/" class="text-muted transition-colors hover:text-navy">Home</a>
			<span class="text-silver">/</span>
			<span class="font-medium text-navy">Contact</span>
		</div>
	</div>

	<!-- Hero -->
	<section class="bg-navy">
		<div class="mx-auto max-w-4xl px-6 py-16 text-center md:px-10">
			<div class="reveal">
				<p class="eyebrow mb-4 text-white/60">Reach us</p>
				<h1 class="text-4xl font-bold text-white md:text-5xl">Get in touch</h1>
				<p class="mx-auto mt-4 max-w-xl text-white/70">
					Based in Kutus, Kirinyaga County. Serving businesses across Kenya and East Africa. We reply within 24 hours — usually much faster.
				</p>
			</div>
		</div>
	</section>

	<!-- Main contact section -->
	<section class="bg-white">
		<div class="mx-auto max-w-7xl px-6 py-20 md:px-10 md:py-28">
			<div class="reveal grid gap-16 md:grid-cols-2">

				<!-- Left: Contact info -->
				<div>
					<h2 class="text-2xl font-bold text-navy">Let's talk about your business</h2>
					<p class="mt-4 text-charcoal">
						Whether you have a clear brief or just a vague idea that your business needs something digital — reach out. We will ask the right questions and tell you honestly what would and wouldn't help.
					</p>

					<div class="mt-10 space-y-6">
						<!-- Location -->
						<div class="flex items-start gap-4">
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-surface">
								<svg class="h-5 w-5 text-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
							</div>
							<div>
								<p class="text-sm font-bold text-navy">Location</p>
								<p class="mt-1 text-charcoal">Kutus, Kirinyaga County, Kenya</p>
								<a
									href="https://maps.google.com/?q=Kutus,Kirinyaga,Kenya"
									target="_blank"
									rel="noopener noreferrer"
									class="mt-1 inline-block text-sm text-navy-bright hover:text-navy"
								>
									View on Google Maps ↗
								</a>
							</div>
						</div>

						<!-- Email -->
						<div class="flex items-start gap-4">
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-surface">
								<svg class="h-5 w-5 text-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
								</svg>
							</div>
							<div>
								<p class="text-sm font-bold text-navy">Email</p>
								<a href="mailto:hello@technosworld.com" class="mt-1 block text-charcoal hover:text-navy-bright">
									hello@technosworld.com
								</a>
							</div>
						</div>

						<!-- WhatsApp - Sam -->
						<div class="flex items-start gap-4">
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-surface">
								<svg class="h-5 w-5 text-navy" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
									<path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.507 3.93 1.395 5.6L0 24l6.556-1.719A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.7-.497-5.27-1.38l-.378-.224-3.892 1.02 1.04-3.8-.247-.392A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
								</svg>
							</div>
							<div>
								<p class="text-sm font-bold text-navy">WhatsApp — Sam</p>
								<a
									href="https://wa.me/254790261628"
									target="_blank"
									rel="noopener noreferrer"
									class="mt-1 block text-charcoal hover:text-navy-bright"
								>
									+254 790 261 628
								</a>
							</div>
						</div>

						<!-- WhatsApp - Japhet -->
						<div class="flex items-start gap-4">
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-surface">
								<svg class="h-5 w-5 text-navy" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
									<path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.507 3.93 1.395 5.6L0 24l6.556-1.719A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.7-.497-5.27-1.38l-.378-.224-3.892 1.02 1.04-3.8-.247-.392A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
								</svg>
							</div>
							<div>
								<p class="text-sm font-bold text-navy">WhatsApp — Japhet</p>
								<a
									href="https://wa.me/254118241577"
									target="_blank"
									rel="noopener noreferrer"
									class="mt-1 block text-charcoal hover:text-navy-bright"
								>
									+254 118 241 577
								</a>
							</div>
						</div>

						<!-- Hours -->
						<div class="flex items-start gap-4">
							<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-surface">
								<svg class="h-5 w-5 text-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div>
								<p class="text-sm font-bold text-navy">Working hours</p>
								<p class="mt-1 text-charcoal">Monday – Friday: 8:00 AM – 6:00 PM EAT</p>
								<p class="text-charcoal">Saturday: 9:00 AM – 1:00 PM EAT</p>
								<p class="mt-1 text-sm text-muted">WhatsApp messages received anytime; we reply during working hours.</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Right: Contact form -->
				<div>
					<div class="rounded-2xl border border-card-border bg-surface p-8">
						<h2 class="text-xl font-bold text-navy">Send us a message</h2>
						<p class="mt-2 text-sm text-muted">We reply within 24 hours, usually much faster.</p>

						<form
							action="mailto:hello@technosworld.com"
							method="POST"
							enctype="text/plain"
							class="mt-6 space-y-5"
						>
							<div class="grid gap-4 sm:grid-cols-2">
								<div>
									<label for="name" class="block text-sm font-medium text-charcoal">Full name <span class="text-navy-bright">*</span></label>
									<input
										type="text"
										id="name"
										name="name"
										required
										placeholder="Your name"
										class="mt-1.5 w-full rounded-lg border border-card-border bg-white px-4 py-2.5 text-sm text-charcoal placeholder:text-muted focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
									/>
								</div>
								<div>
									<label for="email" class="block text-sm font-medium text-charcoal">Email address <span class="text-navy-bright">*</span></label>
									<input
										type="email"
										id="email"
										name="email"
										required
										placeholder="you@example.com"
										class="mt-1.5 w-full rounded-lg border border-card-border bg-white px-4 py-2.5 text-sm text-charcoal placeholder:text-muted focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
									/>
								</div>
							</div>

							<div class="grid gap-4 sm:grid-cols-2">
								<div>
									<label for="phone" class="block text-sm font-medium text-charcoal">Phone / WhatsApp <span class="text-muted text-xs">(optional)</span></label>
									<input
										type="tel"
										id="phone"
										name="phone"
										placeholder="+254 7XX XXX XXX"
										class="mt-1.5 w-full rounded-lg border border-card-border bg-white px-4 py-2.5 text-sm text-charcoal placeholder:text-muted focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
									/>
								</div>
								<div>
									<label for="company" class="block text-sm font-medium text-charcoal">Business / organisation</label>
									<input
										type="text"
										id="company"
										name="company"
										placeholder="Your business name"
										class="mt-1.5 w-full rounded-lg border border-card-border bg-white px-4 py-2.5 text-sm text-charcoal placeholder:text-muted focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
									/>
								</div>
							</div>

							<div>
								<label for="service" class="block text-sm font-medium text-charcoal">Service you're interested in</label>
								<select
									id="service"
									name="service"
									class="mt-1.5 w-full rounded-lg border border-card-border bg-white px-4 py-2.5 text-sm text-charcoal focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
								>
									<option value="">Select a service</option>
									<option value="Website">Website & online presence</option>
									<option value="Software">Business & management software</option>
									<option value="AI tools">AI tools & automation</option>
									<option value="Infrastructure">Digital infrastructure</option>
									<option value="Branding">Branding, print & marketing</option>
									<option value="Not sure">Not sure yet — need advice</option>
								</select>
							</div>

							<div>
								<label for="message" class="block text-sm font-medium text-charcoal">Tell us about your business <span class="text-navy-bright">*</span></label>
								<textarea
									id="message"
									name="message"
									required
									rows="5"
									placeholder="What does your business do? What problem are you trying to solve? What have you tried before?"
									class="mt-1.5 w-full rounded-lg border border-card-border bg-white px-4 py-2.5 text-sm text-charcoal placeholder:text-muted focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy"
								></textarea>
							</div>

							<button
								type="submit"
								class="btn-primary w-full justify-center"
							>
								Send message
							</button>

							<p class="text-center text-xs text-muted">
								Your details are only used to respond to your enquiry. No spam, ever.
							</p>
						</form>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- Bottom location strip -->
	<section class="bg-surface">
		<div class="mx-auto max-w-7xl px-6 py-12 text-center md:px-10">
			<div class="reveal">
				<p class="text-sm text-muted">Technosworld is based in</p>
				<p class="mt-1 text-lg font-bold text-navy">Kutus, Kirinyaga County, Kenya</p>
				<a
					href="https://maps.google.com/?q=Kutus,Kirinyaga,Kenya"
					target="_blank"
					rel="noopener noreferrer"
					class="mt-3 inline-flex items-center gap-1.5 text-sm text-navy-bright hover:text-navy"
				>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
						<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
					</svg>
					Open in Google Maps
				</a>
			</div>
		</div>
	</section>
</Layout>
