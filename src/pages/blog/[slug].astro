---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/blog';
import type { BlogPost } from '../../data/blog';

export function getStaticPaths() {
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

interface Props {
	post: BlogPost;
}

const { post } = Astro.props;
const others = posts.filter((p) => p.slug !== post.slug);
---

<Layout
	title={`${post.title} — Technosworld`}
	description={post.excerpt}
>
	<!-- Breadcrumb -->
	<div class="border-b border-card-border bg-surface">
		<div class="mx-auto flex max-w-7xl items-center gap-2 px-6 py-3 text-sm md:px-10">
			<a href="/" class="text-muted transition-colors hover:text-navy">Home</a>
			<span class="text-silver">/</span>
			<a href="/blog" class="text-muted transition-colors hover:text-navy">Blog</a>
			<span class="text-silver">/</span>
			<span class="line-clamp-1 font-medium text-navy">{post.title}</span>
		</div>
	</div>

	<!-- Article hero -->
	<section class="relative flex h-64 items-end overflow-hidden md:h-[22rem]">
		<img
			src={post.image}
			alt={post.imageAlt}
			class="absolute inset-0 h-full w-full object-cover object-center"
			loading="eager"
		/>
		<div class="absolute inset-0 bg-navy/70"></div>
		<div class="relative z-10 w-full px-6 pb-10 md:px-10">
			<div class="mx-auto max-w-3xl">
				<span class="mb-3 inline-block rounded px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest text-white" style="background:#2441A0">
					{post.category}
				</span>
				<h1 class="text-2xl font-bold leading-snug text-white md:text-4xl">
					{post.title}
				</h1>
				<div class="mt-3 flex items-center gap-3 text-sm text-white/60">
					<span>{post.readTime}</span>
					<span class="text-white/30">·</span>
					<span>{post.date}</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Article body -->
	<section class="bg-white">
		<div class="mx-auto max-w-3xl px-6 py-16 md:px-10 md:py-24">
			<div class="article-body" set:html={post.body} />
		</div>
	</section>

	<!-- More from Technosworld -->
	<section class="bg-surface">
		<div class="mx-auto max-w-7xl px-6 py-16 md:px-10">
			<div class="reveal">
				<p class="eyebrow mb-2">More from Technosworld</p>
				<h2 class="text-2xl font-bold text-navy">Keep reading</h2>
			</div>
			<div class="mt-8 grid gap-6 sm:grid-cols-2">
				{others.map((other) => (
					<a
						href={`/blog/${other.slug}`}
						class="reveal group flex items-start gap-4 overflow-hidden rounded-xl border border-card-border bg-white p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-navy hover:shadow-md"
					>
						<div class="relative h-20 w-28 shrink-0 overflow-hidden rounded-lg">
							<img
								src={other.image}
								alt={other.imageAlt}
								class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
								loading="lazy"
							/>
							<div class="absolute inset-0 bg-navy/55 mix-blend-multiply"></div>
						</div>
						<div class="min-w-0">
							<p class="text-[10px] font-bold uppercase tracking-widest text-muted">{other.category}</p>
							<p class="mt-1 line-clamp-2 text-sm font-bold leading-snug text-navy group-hover:text-navy-bright transition-colors">{other.title}</p>
							<p class="mt-1.5 text-xs text-muted">{other.readTime} · {other.date}</p>
						</div>
					</a>
				))}
			</div>

			<div class="reveal mt-10 text-center">
				<a href="/blog" class="inline-flex items-center gap-1.5 rounded-full border border-navy px-5 py-2 text-sm font-bold text-navy transition-all hover:bg-navy hover:text-white">
					← Back to all articles
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.article-body :global(p) {
		color: #2C3E50;
		font-size: 1rem;
		line-height: 1.8;
		margin-bottom: 1.25rem;
	}
	.article-body :global(h2) {
		color: #1B2D6B;
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		line-height: 1.3;
	}
	.article-body :global(h3) {
		color: #1B2D6B;
		font-size: 1.25rem;
		font-weight: 700;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		line-height: 1.4;
	}
	.article-body :global(strong) {
		color: #1B2D6B;
		font-weight: 700;
	}
	.article-body :global(ul) {
		list-style: disc;
		padding-left: 1.5rem;
		margin-bottom: 1.25rem;
		color: #2C3E50;
	}
	.article-body :global(li) {
		margin-bottom: 0.5rem;
		line-height: 1.7;
	}
</style>
